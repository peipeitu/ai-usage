{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Usage",
  "version": "0.1.0",
  "identifier": "dev.workerpei.aiusage",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Usage",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "appimage", "deb"],
    "category": "DeveloperTool",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "../build/icons/32x32.png",
      "../build/icons/128x128.png",
      "../build/icons/256x256.png",
      "../build/icon.icns",
      "../build/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
