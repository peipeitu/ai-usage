{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Usage",
  "version": "0.1.5",
  "identifier": "dev.workerpei.aiusage",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AI Usage",
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      },
      {
        "label": "tray-status",
        "title": "AI Usage Status",
        "url": "tray.html",
        "width": 320,
        "height": 156,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb"],
    "category": "DeveloperTool",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "../build/icons/32x32.png",
      "../build/icons/128x128.png",
      "../build/icons/256x256.png",
      "../build/icon.icns",
      "../build/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
